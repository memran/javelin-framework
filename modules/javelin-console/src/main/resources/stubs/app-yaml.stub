app:
  name: {{ project }}
  env: ${APP_ENV:local}

server:
  host: 127.0.0.1
  port: ${SERVER_PORT:8080}
  driver: jdk

database:
  driver: postgresql
  host: localhost
  port: 5432
  database: {{ project }}
  username: postgres
  password: secret

log:
  channel: console
  path: storage/logs/app.log

security:
  max_request_bytes: 1048576

providers:
  - app.providers.AppServiceProvider
